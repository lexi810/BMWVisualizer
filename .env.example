ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
DATABASE_URL=sqlite:///./battery_intel.db
UPLOAD_DIR=./uploads

# Optional: NAATBatt spreadsheet URL if NREL changes the download link (defaults to current NREL Excel).
# NAATBATT_URL=https://www.nrel.gov/media/docs/libraries/transportation/naatbatt-database-31march2026.xlsx

# Comma-separated browser origins for CORS (dev defaults include Vite). Use * for any origin (no credentials).
# For production on one host, same-origin requests do not need CORS; add your public URL if the API is called cross-origin.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
